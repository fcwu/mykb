---
layout: null
permalink: /feed.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <link>{{ site.url }}/</link>
    <description>{{ site.description | xml_escape }}</description>
    <atom:link href="{{ site.url }}/feed.xml" rel="self" type="application/rss+xml"/>
    <language>zh-tw</language>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    {% assign all_pages = site.pages | where_exp: "p", "p.category" | sort: "date" | reverse %}
    {% for p in all_pages %}
    <item>
      <title>{{ p.title | xml_escape }}</title>
      <link>{{ p.url | absolute_url }}</link>
      <guid isPermaLink="true">{{ p.url | absolute_url }}</guid>
      <pubDate>{{ p.date | date_to_rfc822 }}</pubDate>
      <category>{{ p.category | xml_escape }}</category>
      {% if p.description %}<description>{{ p.description | xml_escape }}</description>{% endif %}
    </item>
    {% endfor %}
  </channel>
</rss>
